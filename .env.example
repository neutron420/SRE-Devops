# Environment variables for AI DevOps Copilot (Template)

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here

# FastAPI Backend Settings
BACKEND_API_URL=http://localhost:8000
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Database Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=devops_copilot
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ChromaDB Settings
CHROMADB_HOST=chromadb
CHROMADB_PORT=8001
CHROMADB_PERSIST_DIRECTORY=/app/vector-db/chroma_data

# Real Cluster Integration
PROMETHEUS_URL=http://prometheus:9090
K8S_NAMESPACE=default

# SRE Agent Mode: Set to 'true' for local testing with mock data, 'false' for live Kubernetes & Prometheus connection
MOCK_MODE=true

# Proactive SRE Alerting Configuration
DISCORD_ALERT_CHANNEL_ID=your_discord_channel_id_here
ALERT_CPU_THRESHOLD_PCT=90.0
ALERT_MEM_THRESHOLD_PCT=90.0
ALERT_ERROR_RATE_THRESHOLD_PCT=5.0
